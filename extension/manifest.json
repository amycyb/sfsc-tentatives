{
  "manifest_version": 3,
  "name": "SFSC Tentative Rulings",
  "version": "1.1",
  "description": "Send SFSC tentative rulings to GitHub for ingestion.",
  "permissions": ["storage", "scripting", "tabs", "alarms", "downloads"],
  "host_permissions": [
    "https://webapps.sftc.org/*",
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SFSC Tentative Rulings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "commit-and-next": {
      "suggested_key": {
        "default":  "Alt+Shift+S",
        "mac":      "Alt+Shift+S"
      },
      "description": "Commit current SFSC page to GitHub and load the next business day"
    }
  }
}
